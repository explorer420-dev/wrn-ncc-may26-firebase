rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Config — must stay publicly readable; check-in app reads test_day_override without auth.
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Master — requires auth to read; write allowed pre-event for the Apps Script morning import.
    match /master/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null || request.time < timestamp.date(2026, 6, 1);
    }

    // Attendance log — requires auth to read; create allowed until event ends.
    match /attendance_log/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.time < timestamp.date(2026, 6, 1);
      allow update, delete: if false;
    }
  }
}
